# Copy this file to .env and fill in the values.
# Do not commit .env to Git.

# Database (required). Use a PostgreSQL URL for local and Vercel.
# Get a free URL at https://neon.tech or use Vercel Postgres after deploying.
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# Password to log in to the admin area (/admin).
ADMIN_PASSWORD="your-secure-admin-password"

# Full URL where the app runs. Use your Vercel URL after deployment.
# Local: http://localhost:3000
# Production: https://your-app.vercel.app
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Required for the private power page: without this, ON/OFF toggle returns 401.
# Set the same value in Vercel → Environment Variables. Only you should know it.
# POWER_TOGGLE_SECRET="a-long-random-string-only-you-know"
